# Bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# Local databases and artifacts
*.sqlite
*.db

# Runtime state directories (keep placeholders only)
baseline-history/*
!baseline-history/.gitkeep
tmp-test/*
!tmp-test/.gitkeep
web_runs/*
!web_runs/.gitkeep

# Node / frontend build outputs
node_modules/
webapp/frontend/node_modules/
webapp/frontend/dist/
webapp/frontend/.vite/

# Vendored binaries (do not commit large/static tool binaries)
bin/

# Secrets and local credential material
.api_key
web_runs/.api_key
*.pem
*.key
secrets.json
credentials.json
.env

# Misc
.DS_Store
Thumbs.db

# Local Claude Code settings (per-machine, not for the repo)
.claude/settings.local.json

# Personal launch/growth strategy notes — keep local, not for public repo
docs/launch/
docs/growth/huntr-target-shortlist.md
docs/growth/oss-contribution-and-cve-plan.md
